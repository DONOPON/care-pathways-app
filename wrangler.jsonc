{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "saluddigital",
  "main": "./.output/server/index.mjs",
  "compatibility_date": "2025-01-01",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./.output/public/",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
}
